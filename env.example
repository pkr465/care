#.env file for the project

# Where to write output modules, Markdown, and artifacts (defaults to outputpath's dir)
OUT_DIR=./data/generated/md/
FLAT_JSON_PATH=./out/parseddata
REPORT_JSON_PATH=./out/parseddata
GRAPH_PATH=./out/diagrams
PDF_PATH=./out/pdfs

#####################################################################
# All other project or API configuration below (unchanged)
#####################################################################

# Data input/output, LLM, and logging configs (already present)
SOURCE_DIR=./data/
GENERATED_MD_DIR=./data/generated/md/
DOC_FILES=./data/docs/*.docx
CODE_BASE_PATH=./codebase
CHAT_PROMPT_FILE_PATH=./prompts/chat_prompt.md



# Batch mode: folder with input .docx files (if using batch). Must already exist.
WORD_DOC_FOLDER=./data/docs

# File format for input (default: docx)
FORMAT=docx

# Generate TOC in output (True/False)
TOC=False

# Path to 'pandoc' executable
WITH_PANDOC=pandoc

# Enable verbose terminal logging (True/False)
VERBOSE=False

# Debug mode (suppress cleanup, extra logs) (True/False)
DEBUG=False



# Postgres/PGVector (these MAY CHANGE for each user or environment)
# Postgres/PGVector (these MAY CHANGE for each user or environment)

# SQLAlchemy-style connection string for the *app user* (used by your app)
POSTGRES_CONNECTION=postgresql+psycopg2://codebase_analytics_user:postgres@localhost/codebase_analytics_db

# Admin credentials (used only for migrations/setup scripts, if needed)
# Often this is just the default 'postgres' superuser in local dev.
POSTGRES_ADMIN_USERNAME=postgres
POSTGRES_ADMIN_PASSWORD=postgres

# LangChain / pgvector collection configuration
POSTGRES_COLLECTION=codebase_analytics_data_2025
POSTGRES_COLLECTION_TABLENAME=langchain_pg_collection
POSTGRES_EMBEDDING_TABLENAME=langchain_pg_embedding
POSTGRES_STORE_NAME=codebase_analytics_vector_db

# Application DB user (same as in POSTGRES_CONNECTION)
POSTGRES_USERNAME=codebase_analytics_user
POSTGRES_PASSWORD=postgres

# Database name and connection host/port
POSTGRES_DATABASE=codebase_analytics_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# QGenie and LangChain API
QGENIE_API_KEY=
QGENIE_CHAT_ENDPOINT=https://qgenie-chat.qualcomm.com



# Vector DB selection
VECTOR_DATABASE=postgres

# Embedding model - choose either 'qgenie' or 'openai' (optional)
EMBEDDING_MODEL=qgenie

# LLM model (choose only one)
LLM_MODEL=vertexai::gemini-2.5-pro
#LLM_MODEL=anthropic::claude-4-sonnet
#LLM_MODEL=qwen2.5-14b-1m
STREAMLIT_MODEL=vertexai::gemini-2.5-pro

#LLM_MODEL=azure::gpt-4.1
#LLM_MODEL=anthropic::claude-3-7-sonnet
CODING_LLM_MODEL=anthropic::claude-4-sonnet

#STREAMLIT_MODEL=azure::gpt-4.1
PROMPT_FILE_PATH=./prompts/prompt.md
LOG_LEVEL=INFO
EMAIL_ID=pavanr@qti.qualcomm.com
#HPG_LABELING_INSTRUCTIONS=./prompts/hpg_labeling_instructions.md